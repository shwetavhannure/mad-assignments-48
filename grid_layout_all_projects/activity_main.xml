<?xml version="1.0" encoding="utf-8"?>
<GridLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/gridLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:columnCount="3"
    android:rowCount="3"
    android:padding="16dp"
    android:alignmentMode="alignMargins"
    android:useDefaultMargins="true">


    <Button
        android:id="@+id/btnProject1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_columnWeight="1"
        android:text="Hello World"
        android:layout_margin="8dp" />

    <Button
        android:id="@+id/btnProject2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_columnWeight="1"
        android:text="Linear V"
        android:layout_margin="8dp" />

    <Button
        android:id="@+id/btnProject3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_columnWeight="1"
        android:text="Linear H"
        android:layout_margin="8dp" />

    <Button
        android:id="@+id/btnProject4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_columnWeight="1"
        android:text="Relative Layout"
        android:layout_margin="8dp" />

    <Button
        android:id="@+id/btnProject5"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_columnWeight="1"
        android:text="Grid Layout"
        android:layout_margin="8dp" />

    <Button
        android:id="@+id/btnProject6"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_columnWeight="1"
        android:text="Table Layout"
        android:layout_margin="8dp" />

    <Button
        android:id="@+id/btnProject7"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_columnWeight="1"
        android:text="Bg Change"
        android:layout_margin="8dp" />

    <Button
        android:id="@+id/btnProject8"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_columnWeight="1"
        android:text="Profile Page"
        android:layout_margin="8dp" />

    <Button
        android:id="@+id/btnProject9"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_columnWeight="1"
        android:text="Explicit Intent"
        android:layout_margin="8dp" />

</GridLayout>